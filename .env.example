# === App ===
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
MODEL_VERSION=0.1.0

# === MLflow / Databricks ===
MLFLOW_TRACKING_URI=databricks
DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
DATABRICKS_TOKEN=__set_me__
MLFLOW_EXPERIMENT_NAME=/Users/<email>/tc2-recsys

# === DVC remote (S3 exemplo) ===
DVC_REMOTE_URL=s3://<bucket>/tc2/dvc
AWS_ACCESS_KEY_ID=__set_me__
AWS_SECRET_ACCESS_KEY=__set_me__
AWS_DEFAULT_REGION=us-east-1
